# Meridian env. Copy to .env (gitignored) and fill in.

# LLM provider switch: anthropic | groq | mock
LLM_PROVIDER=anthropic

# Anthropic (planner, specialists, judge in production)
ANTHROPIC_API_KEY=

# Groq (free-tier dev fallback; Llama 3.3 70B with tool use)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Web search
TAVILY_API_KEY=

# Local infra (matches docker/docker-compose.yml ports)
DATABASE_URL=postgresql://meridian:meridian@localhost:5455/meridian
REDIS_URL=redis://localhost:6381/0
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# API
API_PORT=8030

# Models (override only if you need to)
ANTHROPIC_PLANNER_MODEL=claude-sonnet-4-6
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_JUDGE_MODEL=claude-opus-4-7
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001

# Embeddings (Phase 1 uses a deterministic pseudo-embedder; Phase 2 swaps to Voyage)
EMBEDDING_DIM=1024
