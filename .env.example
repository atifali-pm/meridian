# Meridian env. Copy to .env (gitignored) and fill in.

# Anthropic (planner, specialists, judge)
ANTHROPIC_API_KEY=

# Web search
TAVILY_API_KEY=

# Local infra (matches docker/docker-compose.yml ports)
DATABASE_URL=postgresql://meridian:meridian@localhost:5455/meridian
REDIS_URL=redis://localhost:6381/0
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# API
API_PORT=8030
